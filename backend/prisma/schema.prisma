generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id
  email          String   @unique
  full_name      String?
  credit_balance Int      @default(0)
  created_at     DateTime @default(now())
  videos         VideoJob[]
  transactions   Transaction[]
  @@map("profiles")
}

model VideoJob {
  id              String   @id @default(uuid())
  user_id         String
  status          String   @default("pending")
  source          String   @default("form")
  app_name        String
  description     String?
  audience        String[]
  cta_goal        String?
  features        String?
  video_length    Int?
  tone            String?
  music_vibe      String?
  animation_code  String?
  production_doc  Json?
  output_url      String?
  credits_used          Int       @default(1)
  render_status         String?
  render_error          String?
  render_started_at     DateTime?
  render_completed_at   DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user            User     @relation(fields: [user_id], references: [id])
  screenshots     Screenshot[]

  @@map("video_jobs")
}

model Screenshot {
  id           String   @id @default(uuid())
  video_job_id String
  file_url     String
  label        String?
  order        Int
  created_at   DateTime @default(now())
  video_job    VideoJob @relation(fields: [video_job_id], references: [id])
}

model Transaction {
  id         String   @id @default(uuid())
  user_id    String
  amount     Int
  credits    Int
  stripe_id  String
  status     String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
}
